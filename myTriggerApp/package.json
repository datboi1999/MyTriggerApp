{
  "name": "trigger-app",
  "version": "1.0.0",
  "description": "TRIGGER - AI-powered growth platform for Nigerian creator economy",
  "main": "index.js",
  "expo": {
    "name": "TRIGGER",
    "slug": "trigger-app",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0F1726"
      }
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo build",
    "eas-build": "eas build"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/stack": "^6.3.0",
    "axios": "^1.6.0",
    "expo": "~50.0.0",
    "expo-build-properties": "^55.0.13",
    "expo-splash-screen": "~0.26.0",
    "expo-status-bar": "~1.11.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-safe-area-context": "^4.7.0",
    "react-native-screens": "^3.25.0",
    "react-native-vector-icons": "^10.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.0",
    "typescript": "^5.0.0"
  },
  "private": true
